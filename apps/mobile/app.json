{
  "expo": {
    "name": "NailStudio 101",
    "slug": "nailstudio101",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nailstudio101",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0A",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nailstudio101.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Profil fotoğrafı çekmek için kamera erişimi gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Galeriyi kullanmak için izin gerekiyor."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.nailstudio101.app",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#C9A84C"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
