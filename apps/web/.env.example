# ── NailStudio 101 — Web (apps/web) environment ─────────────────
# Bu dosyayı `.env.local` olarak kopyalayıp değerleri doldurun.
# Vercel'de bunları Project Settings → Environment Variables'a girin.

# ── Supabase (ZORUNLU) ──────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
# Service role: SADECE sunucuda kullanılır (public booking, upload, admin,
# hatırlatma/cron, push). ASLA client'a sızdırmayın, NEXT_PUBLIC_ yapmayın.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Cron (hatırlatmalar) ────────────────────────────────────────
# /api/cron/reminders bunu "Authorization: Bearer <CRON_SECRET>" ile bekler.
# Vercel Cron, CRON_SECRET tanımlıysa bu header'ı otomatik ekler.
CRON_SECRET=<uzun-rastgele-secret>

# ── SMS (Netgsm) — opsiyonel ────────────────────────────────────
# Yoksa SMS kanalı pasif kalır (hatırlatma satırı oluşturulmaz).
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_FROM=STUDIO101

# ── E-posta (Resend) — opsiyonel ────────────────────────────────
# Yoksa e-posta kanalı pasif kalır.
RESEND_API_KEY=
RESEND_FROM=NailStudio 101 <onboarding@resend.dev>

# ── NOT: Supabase Auth yapılandırması (koddan değil, panelden) ──
# Authentication → URL Configuration:
#   Site URL:       https://<prod-domain>   (dev'de http://localhost:3010)
#   Redirect URLs:  https://<prod-domain>/auth/callback
#                   http://localhost:3010/auth/callback
# Bunlar olmadan e-posta onay / şifre sıfırlama linkleri /auth/callback'e düşmez.
